{
  "name": "@archon/core",
  "version": "0.2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./db": "./src/db/index.ts",
    "./db/*": "./src/db/*.ts",
    "./clients": "./src/clients/index.ts",
    "./workflows": "./src/workflows/index.ts",
    "./workflows/*": "./src/workflows/*.ts",
    "./isolation": "./src/isolation/index.ts",
    "./isolation-store": "./src/db/isolation-environments.ts",
    "./orchestrator": "./src/orchestrator/orchestrator.ts",
    "./handlers": "./src/handlers/command-handler.ts",
    "./config": "./src/config/index.ts",
    "./utils/*": "./src/utils/*.ts",
    "./services/*": "./src/services/*.ts",
    "./state/*": "./src/state/*.ts"
  },
  "scripts": {
    "test": "bun test src/clients/ && bun test src/handlers/ && bun test src/db/ src/utils/ src/config/ src/state/ src/isolation/ && bun test src/services/cleanup-service.test.ts && bun test src/services/title-generator.test.ts && bun test src/workflows/ && bun test src/orchestrator/",
    "type-check": "bun x tsc --noEmit",
    "build": "echo 'No build needed - Bun runs TypeScript directly'"
  },
  "dependencies": {
    "@archon/git": "workspace:*",
    "@archon/isolation": "workspace:*",
    "@archon/paths": "workspace:*",
    "@archon/workflows": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.45",
    "@openai/codex-sdk": "^0.104.0",
    "pg": "^8.11.0",
    "pino": "^9"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
